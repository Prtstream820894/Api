{
  "version": 2,
  "rewrites": [
    {
      "source": "/live.mpd",
      "destination": "/api/index"
    },
    {
      "source": "/api/speedo/(.*).m3u8",
      "destination": "/api/speedo?play=$1"
    },
    {
      "source": "/tata.m3u",
      "destination": "/api/tata.js"
    },
    {
      "source": "/api/license",
      "destination": "/api/license.js"
    }
  ]
}
